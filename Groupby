<!-- DataTables JS -->
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

<script>
    $(document).ready(function() {
        var table = $('#employeeTable').DataTable({
            order: [[0, 'asc']],
            drawCallback: function(settings) {
                var api = this.api();
                var rows = api.rows({page: 'current'}).nodes();
                var last = null;
                var groupColumn = $('#groupByColumn').val();
                
                if (groupColumn !== '') {
                    var groupSums = {};
                    
                    api.column(groupColumn, {page: 'current'}).data().each(function(group, i) {
                        if (last !== group) {
                            // Calculate sum for this group
                            var sum = 0;
                            api.rows({page: 'current'}).every(function() {
                                var data = this.data();
                                if (data[groupColumn] == group) {
                                    sum += parseFloat(data[4]) || 0;
                                }
                            });
                            
                            // Get column name
                            var columnName = api.column(groupColumn).header().textContent;
                            
                            // Insert group row
                            $(rows).eq(i).before(
                                '<tr class="group-row">' +
                                    '<td colspan="5">' +
                                        '<strong>' + columnName + ': ' + group + '</strong>' +
                                        '<span class="salary-sum">Total Salary: $' + sum.toLocaleString() + '</span>' +
                                    '</td>' +
                                '</tr>'
                            );
                            
                            last = group;
                        }
                    });
                }
            }
        });
        
        // Handle group by change
        $('#groupByColumn').on('change', function() {
            var groupColumn = $(this).val();
            
            if (groupColumn !== '') {
                // Sort by the selected column
                table.order([[parseInt(groupColumn), 'asc']]).draw();
            } else {
                // Reset to default sorting
                table.order([[0, 'asc']]).draw();
            }
        });
    });
</script>
